{
	"name": "n8n-nodes-pdfvector",
	"version": "2.0.2",
	"description": "n8n community node for PDF Vector — parse PDF, Word, Excel, and image documents, extract structured data with JSON Schema, ask AI questions, and search academic papers across multiple databases.",
	"keywords": [
		"n8n-community-node-package",
		"pdfvector",
		"PDF",
		"Word",
		"Excel",
		"Image",
		"parse-document",
		"parse-invoice",
		"parse-bank-statement",
		"academic",
		"academic-search",
		"academic-fetch"
	],
	"license": "MIT",
	"homepage": "https://www.pdfvector.com",
	"author": {
		"name": "PDF Vector",
		"email": "team@pdfvector.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/phuctm97/n8n-nodes-pdfvector.git"
	},
	"scripts": {
		"generate": "openapi-typescript https://global.pdfvector.com/api/reference.json -o nodes/PdfVector/shared/pdfvector-api.types.ts",
		"build": "npm run generate && n8n-node build",
		"build:watch": "npm run generate && tsc --watch",
		"dev": "npm run generate && n8n-node dev",
		"lint": "npm run generate && n8n-node lint",
		"lint:fix": "npm run generate && n8n-node lint --fix",
		"release": "npm run generate && n8n-node release",
		"prepublishOnly": "npm run generate && n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PDFVectorApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/PdfVector/PdfVector.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"openapi-typescript": "^7.13.0",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
